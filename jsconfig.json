{
  "compilerOptions": {
    "checkJs": false,
    "baseUrl": "src",
    "paths": {
      "@src/*": ["./*"],
      "@assets/*": ["./assets/*"],
      "@components/*": ["./components/*"],
      "@data/*": ["./data/*"],
      "@provider/*": ["./provider/*"],
      "@redux/*": ["./redux/*"],
      "@routes/*": ["./routes/*"],
      "@styles/*": ["./styles/*"]
    }
  },
  "include": [
    "./src/**/*"
  ]
}